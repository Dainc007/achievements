{
    "name": "dainc007/achievements",
    "description": "A reusable, event-driven achievement / badge engine for Laravel, with an optional Filament v5 layer.",
    "type": "library",
    "license": "proprietary",
    "keywords": [
        "laravel",
        "achievements",
        "badges",
        "gamification",
        "filament"
    ],
    "authors": [
        {
            "name": "Daniel Heinze"
        }
    ],
    "require": {
        "php": "^8.4",
        "illuminate/contracts": "^13.0",
        "illuminate/database": "^13.0",
        "illuminate/support": "^13.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "filament/filament": "^5.0",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "pestphp/pest-plugin-livewire": "^4.1",
        "rector/rector": "^2.5"
    },
    "suggest": {
        "filament/filament": "Required only to use the optional Filament admin + badge-wall layer (^5.0)."
    },
    "extra": {
        "laravel": {
            "providers": [
                "Dainc007\\Achievements\\AchievementsServiceProvider"
            ]
        }
    },
    "autoload": {
        "psr-4": {
            "Dainc007\\Achievements\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dainc007\\Achievements\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest",
        "test-unit": "pest --group=unit",
        "lint": "pint",
        "rector": "rector process",
        "analyse": "phpstan analyse --memory-limit=512M",
        "quality": [
            "pint --test",
            "rector process --dry-run",
            "phpstan analyse --memory-limit=512M",
            "pest"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
